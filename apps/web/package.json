{
  "name": "@mi-log/web",
  "version": "0.1.0",
  "description": "mi-log reader and local admin web interface.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "build": "tsc && MI_LOG_PUBLIC_RELEASE_BUILD=true vite build",
    "build:desktop": "tsc && VITE_MI_LOG_DESKTOP_BUILD=true vite build --outDir dist-desktop",
    "preview": "vite preview --host 127.0.0.1 --port 5173",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@simplewebauthn/browser": "^13.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.2"
  }
}
