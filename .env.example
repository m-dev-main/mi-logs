NODE_ENV=development

API_HOST=127.0.0.1
API_PORT=4000

STATIC_RELEASE_DIR=releases/latest/public
STATIC_HOST=127.0.0.1
STATIC_PORT=4080

WEB_HOST=127.0.0.1
WEB_PORT=5173
WEB_ORIGIN=http://127.0.0.1:5173

MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB_NAME=mi_log

EXPOSE_ADMIN=false

WEBAUTHN_RP_NAME=mi-log
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:5173
ADMIN_SESSION_TTL_SECONDS=86400

AUTHOR_KEY_DIR=keys/private
AUTHOR_PUBLIC_KEY_PATH=keys/author.pub

# One-time secret for the very first owner passkey registration (Authorization: Bearer).
# Generate with e.g. `openssl rand -hex 32` — never commit a real value. Restart the API after changes.
OWNER_REGISTRATION_TOKEN=
